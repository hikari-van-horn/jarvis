{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Jarvis (Discord & Telegram)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "exts=discord,telegram"
            ],
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        },
        {
            "name": "Python: Debug Jarvis (Discord Only)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "exts=discord"
            ],
            "envFile": "${workspaceFolder}/.env",
            "justMyCode": true
        }
    ]
}
